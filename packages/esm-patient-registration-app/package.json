{
  "name": "@intellisoftkenya/esm-patient-registration-app",
  "version": "1.0.3-pre.1",
  "description": "Patient registration microfrontend for O3",
  "browser": "dist/intellisoftkenya-esm-patient-registration-app.js",
  "main": "src/index.ts",
  "source": true,
  "license": "MPL-2.0",
  "homepage": "https://github.com/openmrs/openmrs-esm-patient-management#readme",
  "scripts": {
    "start": "openmrs develop",
    "serve": "rspack serve --mode=development",
    "debug": "npm run serve",
    "build": "rspack --mode=production",
    "analyze": "rspack --mode=production --env analyze=true",
    "lint": "eslint src --ext ts,tsx",
    "typescript": "tsc",
    "extract-translations": "i18next 'src/**/*.component.tsx' 'src/index.ts' --config ../../tools/i18next-parser.config.js",
    "test": "cross-env TZ=UTC jest --config jest.config.js --verbose false --passWithNoTests",
    "test:watch": "cross-env TZ=UTC jest --watch --config jest.config.js",
    "coverage": "yarn test --coverage"
  },
  "browserslist": [
    "extends browserslist-config-openmrs"
  ],
  "keywords": [
    "openmrs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IntelliSOFT-Consulting/eHospital3.x-Apps#readme"
  },
  "bugs": {
    "url": "https://github.com/IntelliSOFT-Consulting/eHospital3.x-Apps/issues"
  },
  "peerDependencies": {
    "@carbon/react": "1.x",
    "@openmrs/esm-framework": "6.x",
    "react": "^18.1.0",
    "react-i18next": "11.x",
    "react-router-dom": "6.x",
    "swr": "2.x"
  },
  "gitHead": "784dcb688faafdd325af974d79cebd5bf38f4c49",
  "dependencies": {
    "dexie": "^4.4.4",
    "formik": "^2.4.9",
    "yup": "^1.7.1"
  }
}
